<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base app theme. Compose drives the real UI colors; this only needs to
         provide a sane window background and status-bar behaviour. -->
    <style name="Theme.VibeFlow" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@color/brand</item>
        <item name="android:windowBackground">@color/white</item>
    </style>

    <style name="Theme.VibeFlow.Transparent" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:windowAnimationStyle">@android:style/Animation.Dialog</item>
    </style>
</resources>
