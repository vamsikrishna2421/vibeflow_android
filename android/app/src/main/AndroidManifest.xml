<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <!-- INTERNET: the managed AI-polish tier (proxy) + Google sign-in, and the optional
         on-demand offline-model download. Speech recognition itself is on-device; your
         voice never leaves the phone. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Detect Wi-Fi vs metered so the ~180 MB noise-model auto-download only runs on Wi-Fi. -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- Floating mic bubble: draw-over-apps overlay + a microphone foreground service. -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />

    <uses-feature android:name="android.hardware.microphone" android:required="true" />

    <!-- Resolve the destination app's icon + name in History. Querying launchable apps
         is Play-compliant (NOT the sensitive QUERY_ALL_PACKAGES). -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
    </queries>

    <application
        android:name=".VibeFlowApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.VibeFlow"
        tools:targetApi="34">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:windowSoftInputMode="adjustResize"
            android:screenOrientation="portrait"
            android:configChanges="orientation|screenSize|smallestScreenSize|screenLayout|keyboardHidden|uiMode"
            android:theme="@style/Theme.VibeFlow">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- The Mynah voice keyboard (Input Method Editor). -->
        <service
            android:name=".ime.VibeFlowImeService"
            android:exported="true"
            android:label="@string/ime_label"
            android:permission="android.permission.BIND_INPUT_METHOD">
            <intent-filter>
                <action android:name="android.view.InputMethod" />
            </intent-filter>
            <meta-data
                android:name="android.view.im"
                android:resource="@xml/method" />
        </service>

        <!-- Quick Settings tile: dictate from anywhere into the clipboard. -->
        <service
            android:name=".capture.VibeFlowTileService"
            android:exported="true"
            android:icon="@drawable/ic_mic_tile"
            android:label="@string/tile_label"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
            <meta-data
                android:name="android.service.quicksettings.ACTIVE_TILE"
                android:value="false" />
        </service>

        <!-- Transparent activity that hosts the floating dictation overlay from the tile. -->
        <activity
            android:name=".capture.CaptureActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:launchMode="singleTop"
            android:theme="@style/Theme.VibeFlow.Transparent" />

        <!-- DEBUG-ONLY: prompt-tuning eval harness, triggered via `adb am start`. Exported so adb
             can launch it; runs cases from assets through the managed proxy and logs to VFEVAL.
             REMOVE before any public release. -->
        <activity
            android:name=".eval.EvalActivity"
            android:exported="true"
            android:excludeFromRecents="true"
            android:theme="@style/Theme.VibeFlow.Transparent" />

        <!-- Floating mic bubble: dictate from anywhere while using any keyboard. -->
        <service
            android:name=".capture.FloatingMicService"
            android:exported="false"
            android:foregroundServiceType="microphone" />

        <!-- Opt-in auto-insert: types dictated text at the cursor + syncs the bubble to the
             keyboard. OFF by default; the user must enable it in Accessibility settings. -->
        <service
            android:name=".accessibility.VibeFlowAccessibilityService"
            android:exported="false"
            android:label="@string/accessibility_service_label"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- Whisper inference runs in its OWN process so the heavy model can't OOM-kill the
             keyboard/bubble process. If :asr is killed, callers just get an empty result. -->
        <service
            android:name=".asr.WhisperAsrService"
            android:exported="false"
            android:process=":asr" />
    </application>
</manifest>
