# VibeFlow admin dashboard — copy to .env.local for local dev, and set the same in Vercel.
# NONE of these are exposed to the browser (no NEXT_PUBLIC_ prefix) — server-side only.

# Supabase (Project Settings → API)
SUPABASE_URL=https://emvstripgwywhcuxgjeg.supabase.co
SUPABASE_SERVICE_ROLE_KEY=__paste_service_role_key_here__

# Admin gate
ADMIN_PASSWORD=__choose_a_strong_password__
# A long random string — the value stored in the auth cookie (rotate to force re-login).
ADMIN_SESSION_TOKEN=__random_long_secret__
